# Pzhisen environment — copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://pzhisen.online

# AI (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CEO_MODEL=anthropic/claude-sonnet-4
OPENROUTER_SITE_URL=https://pzhisen.online
OPENROUTER_SITE_NAME=Pzhisen

# Data persistence (JSON file; use volume mount in production)
DATA_DIR=./data

# ─── PayPal (国际用户 — 收款至您的 PayPal 商户账户) ───
# https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
# sandbox = 测试 | live = 正式收款

# ─── 虎皮椒 XunhuPay (国内微信/支付宝 — 收款至您的虎皮椒账户) ───
# 注册: https://www.xunhupay.com/  绑定您的微信/支付宝收款
XUNHU_APP_ID=
XUNHU_APP_SECRET=
# XUNHU_API_URL=https://api.xunhupay.com/payment/do.html
