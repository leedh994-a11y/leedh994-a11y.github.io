# Auth
JWT_SECRET=
SESSION_SECRET=
OTP_EXPIRY_MINUTES=10
OTP_DEV_EXPOSE=false

# Email OTP (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pzhisen.online

NODE_ENV=production
PUBLIC_URL=https://pzhisen.online

OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://pzhisen.online
# OpenRouter vision model for image chat (optional)
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
DATA_DIR=./data

# PayPal (international)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# China bank transfer (free — your receiving bank card)
BANK_ACCOUNT_NAME=
BANK_NAME=
BANK_ACCOUNT_NUMBER=
BANK_BRANCH=
BILLING_ADMIN_SECRET=

# Comma-separated emails with permanent lifetime access (optional, in addition to built-in restores)
LIFETIME_EMAILS=
