# Pzhisen environment — copy to .env and fill in values

# Server
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://pzhisen.com

# AI (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_CEO_MODEL=anthropic/claude-sonnet-4

# Optional: site metadata for OpenRouter rankings
OPENROUTER_SITE_URL=https://pzhisen.com
OPENROUTER_SITE_NAME=Pzhisen

# Data persistence (JSON file; use volume mount in production)
DATA_DIR=./data
